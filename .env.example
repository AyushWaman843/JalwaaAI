# GROQ AI (Required - Get from https://console.groq.com)
VITE_GROQ_API_KEY="your_groq_api_key"
VITE_GROQ_MODEL="llama-3.3-70b-versatile"

# SUPABASE (Required - Get from https://supabase.com)
VITE_SUPABASE_URL="your_supabase_url"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"

# APIFY (Required - Get from https://apify.com)
VITE_APIFY_API_TOKEN="your_apify_token"
VITE_APIFY_MAX_CALLS="1000"
VITE_APIFY_CACHE_TTL="2592000"

# TWILIO (Optional - for WhatsApp OTP)
VITE_TWILIO_ACCOUNT_SID="your_twilio_sid"
VITE_TWILIO_AUTH_TOKEN="your_twilio_auth_token"
VITE_TWILIO_WHATSAPP_NUMBER="+1234567890"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"
